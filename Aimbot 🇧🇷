    local selected = default
    local selBtn = Instance.new("TextButton")
    selBtn.Size = UDim2.new(1, -20, 0, 18); selBtn.Position = UDim2.new(0, 10, 0, 17)
    selBtn.BackgroundColor3 = C.BG; selBtn.Text = "▼  " .. selected
    selBtn.TextColor3 = C.TextW; selBtn.Font = Enum.Font.Gotham; selBtn.TextSize = 11
    selBtn.BorderSizePixel = 0; selBtn.Parent = card; corner(6, selBtn)
    local expanded = false
    local optFrame = newFrame(UDim2.new(1, -20, 0, 0), UDim2.new(0, 10, 0, 38), C.Card, card, 6)
    optFrame.Visible = false; optFrame.ZIndex = 5
    local optLayout = Instance.new("UIListLayout"); optLayout.Parent = optFrame

    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 22); optBtn.BackgroundColor3 = C.BG
        optBtn.Text = opt; optBtn.TextColor3 = C.TextMid
        optBtn.Font = Enum.Font.Gotham; optBtn.TextSize = 11; optBtn.BorderSizePixel = 0; optBtn.Parent = optFrame
        optBtn.MouseEnter:Connect(function() optBtn.BackgroundColor3 = C.Accent; optBtn.TextColor3 = C.TextW end)
        optBtn.MouseLeave:Connect(function() optBtn.BackgroundColor3 = C.BG; optBtn.TextColor3 = C.TextMid end)
        optBtn.MouseButton1Click:Connect(function()
            selected = opt; selBtn.Text = "▼  " .. selected
            expanded = false; optFrame.Visible = false
            card.Size = UDim2.new(1, -10, 0, 38)
            if callback then callback(selected) end
        end)
    end
    selBtn.MouseButton1Click:Connect(function()
        expanded = not expanded; optFrame.Visible = expanded
        if expanded then
            optFrame.Size = UDim2.new(1, -20, 0, #options * 22)
            card.Size = UDim2.new(1, -10, 0, 38 + #options * 22)
        else
            card.Size = UDim2.new(1, -10, 0, 38)
        end
    end)
    return {Set = function(v) selected = v; selBtn.Text = "▼  " .. v end, Get = function() return selected end}
end

