local function corner(r, p)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r); c.Parent = p
end

local function stroke(th, col, p)
    local s = Instance.new("UIStroke"); s.Thickness = th; s.Color = col; s.Parent = p
end

local function newFrame(sz, pos, col, parent, rad)
    local f = Instance.new("Frame")
    f.Size = sz; f.Position = pos; f.BackgroundColor3 = col; f.BorderSizePixel = 0; f.Parent = parent
    if rad then corner(rad, f) end
    return f
end

local function newLabel(txt, size, col, parent, bold, xalign)
    local l = Instance.new("TextLabel")
    l.Text = txt; l.TextSize = size; l.TextColor3 = col
    l.BackgroundTransparency = 1
    l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextXAlignment = xalign or Enum.TextXAlignment.Left
    l.Size = UDim2.new(1, 0, 0, size + 6); l.Parent = parent
    return l
end

local function newToggle(parent, text, default, callback)
    local card = newFrame(UDim2.new(1, -10, 0, 38), UDim2.new(0, 5, 0, 0), C.Card, parent, 8)
    local lbl = newLabel(text, 12, C.TextW, card, false)
    lbl.Position = UDim2.new(0, 10, 0, 10); lbl.Size = UDim2.new(0.65, 0, 0, 18)
    local btnBg = newFrame(UDim2.new(0, 38, 0, 20), UDim2.new(1, -48, 0, 9), C.BG, card, 10)
    local dot = newFrame(UDim2.new(0, 14, 0, 14), UDim2.new(0, 3, 0, 3), C.TextDim, btnBg, 7)
    local state = default

    local function update()
        if state then
            btnBg.BackgroundColor3 = C.Green
            dot.Position = UDim2.new(0, 21, 0, 3); dot.BackgroundColor3 = C.TextW
        else
            btnBg.BackgroundColor3 = C.BG
            dot.Position = UDim2.new(0, 3, 0, 3); dot.BackgroundColor3 = C.TextDim
        end
    end
    update()

    local function flip()
        state = not state; update()
        if callback then callback(state) end
    end
    btnBg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then flip() end end)
    card.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then flip() end end)
    return {Set = function(v) state = v; update() end, Get = function() return state end}
end

local function newSlider(parent, text, min, max, default, callback)
    local card = newFrame(UDim2.new(1, -10, 0, 55), UDim2.new(0, 5, 0, 0), C.Card, parent, 8)
    local lbl = newLabel(text, 11, C.TextMid, card, false)
    lbl.Position = UDim2.new(0, 10, 0, 4); lbl.Size = UDim2.new(1, -20, 0, 14)
    local valLbl = newLabel(tostring(default), 10, C.TextW, card, false, Enum.TextXAlignment.Center)
    valLbl.Position = UDim2.new(0, 0, 0, 20); valLbl.Size = UDim2.new(1, 0, 0, 12)
    local bar = newFrame(UDim2.new(1, -20, 0, 4), UDim2.new(0, 10, 0, 38), C.BG, card, 2)
    local fill = newFrame(UDim2.new((default - min) / (max - min), 0, 1, 0), UDim2.new(0, 0, 0, 0), C.Accent, bar, 2)
    local value = default

    local function update()
        local pct = (value - min) / (max - min)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        valLbl.Text = max <= 1 and string.format("%.2f", value) or tostring(math.floor(value))
    end

    bar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            local con
            con = UserInputService.InputChanged:Connect(function(m)
                if m.UserInputType == Enum.UserInputType.MouseMovement then
                    local rel = math.clamp((m.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    value = min + rel * (max - min)
                    if max > 1 then value = math.floor(value) end
                    update()
                    if callback then callback(value) end
                end
            end)
            UserInputService.InputEnded:Connect(function(e)
                if e.UserInputType == Enum.UserInputType.MouseButton1 then con:Disconnect() end
            end)
        end
    end)
    return {Set = function(v) value = v; update() end, Get = function() return value end}
end

