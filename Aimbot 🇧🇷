        FOVCircle.Visible = Cfg.ShowFOV
        FOVCircle.Radius = Cfg.FOVSize
        FOVCircle.Color = Cfg.FOVColor
        FOVCircle.Position = center
    end

    if drawOk then
        if DotCross then DotCross.Visible = false end
        if CircleCross then CircleCross.Visible = false end
        if HLine then HLine.Visible = false end
        if VLine then VLine.Visible = false end

        if Cfg.Crosshair then
            local cc = Cfg.CrosshairColor
            local cs = Cfg.CrosshairSize
            if Cfg.CrosshairType == "Ponto" and DotCross then
                DotCross.Visible = true
                DotCross.Radius = math.max(2, cs / 4)
                DotCross.Color = cc
                DotCross.Position = center
            elseif Cfg.CrosshairType == "Círculo" and CircleCross then
                CircleCross.Visible = true
                CircleCross.Radius = cs
                CircleCross.Color = cc
                CircleCross.Position = center
            elseif Cfg.CrosshairType == "Cruz" and HLine and VLine then
                HLine.Visible = true; HLine.Color = cc
                HLine.From = Vector2.new(center.X - cs, center.Y)
                HLine.To = Vector2.new(center.X + cs, center.Y)
                VLine.Visible = true; VLine.Color = cc
                VLine.From = Vector2.new(center.X, center.Y - cs)
                VLine.To = Vector2.new(center.X, center.Y + cs)
            end
        end
    end

    if Cfg.Aimbot then
        local t = findTarget()
        if t then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, t.Position), Cfg.Smoothing)
        end
    end
end)

