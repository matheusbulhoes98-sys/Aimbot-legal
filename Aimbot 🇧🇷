local function getAimPart(char)
    if Cfg.AimPart == "Torso" then
        return char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
    end
    return char:FindFirstChild(Cfg.AimPart)
end

local function findTarget()
    local target  = nil
    local maxDist = Cfg.FOVSize
    local center  = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            if Cfg.TeamCheck and v.Team == LocalPlayer.Team then continue end
            local part = getAimPart(v.Character)
            local hum  = v.Character:FindFirstChild("Humanoid")
            if part and hum and hum.Health > 0 then
                if Cfg.TargetMode == "Selecionado" and v.Name ~= Cfg.SelectedPlayer then continue end
                if Cfg.VisibleCheck then
                    local rp = RaycastParams.new()
                    rp.FilterType = Enum.RaycastFilterType.Exclude
                    rp.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
                    local dir = part.Position - Camera.CFrame.Position
                    local ray = workspace:Raycast(Camera.CFrame.Position, dir, rp)
                    if ray and not ray.Instance:IsDescendantOf(v.Character) then continue end
                end
                local pos, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if mag < maxDist then target = part; maxDist = mag end
                end
            end
        end
    end
    return target
end

