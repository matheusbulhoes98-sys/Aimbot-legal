local function updateESP(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end

    local box = char:FindFirstChild("NexusESP_Box")
    if Cfg.EspBox then
        if not box then
            box = Instance.new("Highlight")
            box.Name = "NexusESP_Box"
            box.FillTransparency = 1
            box.OutlineColor = Color3.fromRGB(255, 0, 0)
            box.OutlineTransparency = 0
            box.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            box.Parent = char
        end
    else
        if box then box:Destroy() end
    end

    local nameGui = char:FindFirstChild("NexusESP_NameGui")
    if Cfg.EspName then
        local head = char:FindFirstChild("Head")
        if head then
            if not nameGui then
                nameGui = Instance.new("BillboardGui")
                nameGui.Name = "NexusESP_NameGui"
                nameGui.AlwaysOnTop = true
                nameGui.Size = UDim2.new(0, 150, 0, 30)
                nameGui.StudsOffset = Vector3.new(0, 2.5, 0)
                local lbl = Instance.new("TextLabel")
                lbl.BackgroundTransparency = 1
                lbl.Size = UDim2.new(1, 0, 1, 0)
                lbl.Font = Enum.Font.SourceSansBold
                lbl.TextSize = 14
                lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                lbl.TextStrokeTransparency = 0
                lbl.Parent = nameGui
                nameGui.Parent = head
            end
            local t = nameGui:FindFirstChild("TextLabel")
            if t then t.Text = player.Name end
        end
    else
        if nameGui then nameGui:Destroy() end
    end

    local healthGui = char:FindFirstChild("NexusESP_HealthGui")
    if Cfg.EspHealth then
        local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
        local hum = char:FindFirstChild("Humanoid")
        if root and hum then
            if not healthGui then
                healthGui = Instance.new("BillboardGui")
                healthGui.Name = "NexusESP_HealthGui"
                healthGui.AlwaysOnTop = true
                healthGui.Size = UDim2.new(0, 80, 0, 30)
                healthGui.StudsOffset = Vector3.new(-2.8, 0, 0)
                local lbl = Instance.new("TextLabel")
                lbl.BackgroundTransparency = 1
                lbl.Size = UDim2.new(1, 0, 1, 0)
                lbl.Font = Enum.Font.SourceSansBold
                lbl.TextSize = 13
                lbl.TextStrokeTransparency = 0
                lbl.TextXAlignment = Enum.TextXAlignment.Right
                lbl.Parent = healthGui
                healthGui.Parent = root
            end
            local lbl = healthGui:FindFirstChild("TextLabel")
            if lbl then
                local vida = math.floor(hum.Health)
                lbl.Text = vida .. " HP"
                if vida > 50 then lbl.TextColor3 = Color3.fromRGB(0, 255, 0)
                elseif vida > 25 then lbl.TextColor3 = Color3.fromRGB(255, 165, 0)
                else lbl.TextColor3 = Color3.fromRGB(255, 0, 0) end
            end
        end
    else
        if healthGui then healthGui:Destroy() end
    end

    if Cfg.EspSkeleton then
        for _, child in pairs(char:GetChildren()) do
            if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then
                if not child:FindFirstChild("NexusESP_Bone") then
                    local bone = Instance.new("BoxHandleAdornment")
                    bone.Name = "NexusESP_Bone"
                    bone.Size = Vector3.new(0.2, child.Size.Y + 0.2, 0.2)
                    if child.Name == "Head" then bone.Size = Vector3.new(0.4, 0.4, 0.4) end
                    bone.Color3 = Color3.fromRGB(255, 255, 255)
                    bone.AlwaysOnTop = true
                    bone.ZIndex = 6
                    bone.Adornee = child
                    bone.Parent = child
                end
            end
        end
    else
        for _, child in pairs(char:GetChildren()) do
            if child:IsA("BasePart") then
                local b = child:FindFirstChild("NexusESP_Bone")
                if b then b:Destroy() end
            end
        end
    end
end

